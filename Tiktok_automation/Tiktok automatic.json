        "jsCode": "const raw = $input.first().json.output\n\nconst cleaned = raw.replace(/```json|```/g, \"\").trim();\n\nconst data = JSON.parse(cleaned);\n\n\nconst result = {\n  hashtag1: data.hashtags[0] || null,\n  hashtag2: data.hashtags[1] || null,\n  hashtag3: data.hashtags[2] || null\n};\n\n\nreturn [{ json: result }];"
